{
  "display_name": "fkanban",
  "description": "A kanban board over fold_db. Two record types (Card, Board) under the `fkanban/*` app namespace; cards move through columns (backlog → todo → doing → done) and every change persists in folddb. Ships a CLI and an MCP server.",
  "homepage_url": "https://github.com/EdgeVector/fkanban",
  "host_track": {
    "app": "kanban",
    "install_mode": "artifact",
    "kind": "artifact-bundle",
    "command": "kanban",
    "aliases": [
      "fkanban",
      "kanban-mcp",
      "fkanban-mcp",
      "kanban-host-track-refresh"
    ],
    "gate": "lastgit",
    "gate_main": "lastdb:///fkanban#main",
    "artifact_app": "fkanban",
    "artifact_channel": "stable",
    "artifact_root": "$HOME/.lastgit/artifacts",
    "install_root": "$HOME/.host-track/apps/fkanban",
    "links": [
      {
        "source": "dist/kanban",
        "target": "$HOME/.local/bin/kanban"
      },
      {
        "source": "dist/fkanban",
        "target": "$HOME/.local/bin/fkanban"
      },
      {
        "source": "dist/kanban-mcp",
        "target": "$HOME/.local/bin/kanban-mcp"
      },
      {
        "source": "dist/fkanban-mcp",
        "target": "$HOME/.local/bin/fkanban-mcp"
      }
    ],
    "notes": "Verified LastGit artifact install; PATH links point into the immutable Host Track artifact bundle."
  }
}
