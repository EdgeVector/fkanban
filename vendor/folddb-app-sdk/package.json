{
  "name": "@folddb/app-sdk",
  "version": "0.1.0",
  "description": "Runtime SDK for FoldDB apps — connect, request consent, and query/mutate a node's /api/* surface with a capability.",
  "license": "MIT",
  "keywords": [
    "folddb",
    "sdk",
    "consent",
    "capability",
    "local-first",
    "personal-data"
  ],
  "homepage": "https://github.com/EdgeVector/fold/tree/main/folddb_app_sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdgeVector/fold.git",
    "directory": "folddb_app_sdk"
  },
  "bugs": {
    "url": "https://github.com/EdgeVector/fold/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
