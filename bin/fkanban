#!/usr/bin/env bash
# fkanban — global shim. Resolves to this repo's src/cli.ts and runs it under
# bun, so a bare `fkanban <cmd>` works from anywhere on PATH.
#
# Install (one-liner, reversible): symlink this script into a PATH dir, e.g.
#   ln -sf "$PWD/bin/fkanban" /usr/local/bin/fkanban    # run from the repo root
# Removing the symlink fully reverses it — nothing is published to a registry.
#
# Follow symlinks so the repo's src/cli.ts is found even when invoked via a
# symlink in ~/bin or /usr/local/bin.
set -euo pipefail

src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ "$src" != /* ]] && src="$dir/$src"
done
dir="$(cd -P "$(dirname "$src")" && pwd)"

exec bun run "$dir/../src/cli.ts" "$@"
